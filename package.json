{
  "name": "error-sonar",
  "displayName": "Error Sonar",
  "description": "Play configurable sounds when code or terminal errors occur.",
  "version": "0.1.0",
  "publisher": "Bharanitharan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BharanitharanKR/fahh_extension"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "error",
    "sound",
    "terminal",
    "diagnostics",
    "alerts"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Error Sonar",
      "properties": {
        "errorSonar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Error Sonar."
        },
        "errorSonar.cooldownMs": {
          "type": "number",
          "default": 1200,
          "minimum": 0,
          "description": "Minimum time in milliseconds between sounds."
        },
        "errorSonar.codeErrorSoundPath": {
          "type": "string",
          "default": "",
          "description": "Absolute or workspace-relative path for code error sound. If empty, extension uses media/fahh.mp3."
        },
        "errorSonar.terminalErrorSoundPath": {
          "type": "string",
          "default": "",
          "description": "Absolute or workspace-relative path for terminal error sound. If empty, extension uses media/fahh.mp3."
        },
        "errorSonar.notifyOnStart": {
          "type": "boolean",
          "default": true,
          "description": "Show a startup notification when the extension activates."
        },
        "errorSonar.showErrorMessages": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code error notification with the latest diagnostics error."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "lint": "eslint src --ext .ts",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
